# Vorlage für Zugangsdaten — Kopiere diese Datei zu ".env" und trage dort die echten Werte ein.
# Die Datei ".env" NIEMALS in Git einchecken oder öffentlich hochladen (siehe .gitignore).

# --- SMTP / Postfach für automatische Mails (Bestätigung, Passwort-Reset) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_FROM_ADDRESS=noreply@südsalat.eu
SMTP_FROM_NAME=Südsalat

# --- Datenbank (MySQL auf Strato) ---
DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=

# --- Sonstiges ---
# APP_URL=https://www.südsalat.eu

# --- Cronjob-Absicherung (RSS-Sync per URL, siehe cron/sync-episodes.php) ---
CRON_SECRET=

# --- API-Auth fuer die App (anonyme Geraete-Tokens, siehe lib/Jwt.php) ---
# JWT_SECRET: zufaelliger 256-bit-Schluessel, z.B. per "openssl rand -hex 32" erzeugen.
JWT_SECRET=
# APP_SECRET: Wert, den die App beim Geraete-Registrieren im X-App-Secret-Header mitschickt
# (per --dart-define beim Flutter-Build gesetzt, siehe 04-App). Kein Kryptografie-Schutz,
# nur ein Filter gegen zufaellige Bot-Anfragen an api/auth/device.php.
APP_SECRET=
# Solange "false": fehlende/ungueltige Tokens werden nur geloggt, nicht mit 401 abgelehnt
# (Kompatibilitaet mit bereits installierten App-Versionen ohne Token-Code). Erst auf
# "true" stellen, wenn die neue App-Version ausgerollt ist - siehe Migrations-Plan.
API_AUTH_ENFORCE=false
